<Window x:Class="BookApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BookApp.ViewModels"
        Title="BookApp" Height="600" Width="800"
        Background="#F5F5F5">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid Margin="10">
        <ContentControl Content="{Binding CurrentView}">
            <ContentControl.Resources>
                <!-- Экран входа/регистрации -->
                <DataTemplate DataType="{x:Type vm:LoginRegisterViewModel}">
                    <TabControl>
                        <TabItem Header="Вход">
                            <StackPanel Margin="10">
                                <Label Content="Имя пользователя"/>
                                <TextBox Text="{Binding LoginUsername}"/>
                                <Label Content="Пароль"/>
                                <PasswordBox x:Name="LoginPasswordBox" PasswordChanged="LoginPasswordBox_PasswordChanged"/>
                                <Button Content="Войти" Command="{Binding LoginCommand}" Margin="0,10,0,0" Background="#0078D4" Foreground="White"/>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="Регистрация">
                            <StackPanel Margin="10">
                                <Label Content="Имя пользователя"/>
                                <TextBox Text="{Binding RegisterUsername}"/>
                                <Label Content="Email"/>
                                <TextBox Text="{Binding RegisterEmail}"/>
                                <Label Content="Пароль"/>
                                <PasswordBox x:Name="RegisterPasswordBox" PasswordChanged="RegisterPasswordBox_PasswordChanged"/>
                                <Label Content="Повторите пароль"/>
                                <PasswordBox x:Name="RegisterConfirmPasswordBox" PasswordChanged="RegisterConfirmPasswordBox_PasswordChanged"/>
                                <Button Content="Зарегистрироваться" Command="{Binding RegisterCommand}" Margin="0,10,0,0" Background="#0078D4" Foreground="White"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </DataTemplate>
                <!-- Экран читалки -->
                <DataTemplate DataType="{x:Type vm:ReaderViewModel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Меню вкладок -->
                        <Menu Grid.Row="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                            <MenuItem Header="Книги">
                                <MenuItem Header="Открыть книгу" Command="{Binding OpenBookCommand}"/>
                                <MenuItem Header="Избранные книги" Command="{Binding ShowFavoritesCommand}"/>
                                <MenuItem Header="История чтения" Command="{Binding ShowHistoryCommand}"/>
                            </MenuItem>
                            <MenuItem Header="Оформление" Command="{Binding ShowSettingsCommand}"/>
                            <MenuItem Header="Рекомендации" Command="{Binding ShowRecommendationsCommand}"/>
                        </Menu>
                        <!-- Динамическое содержимое -->
                        <ContentControl Grid.Row="1" Margin="10" Content="{Binding CurrentContent}">
                            <ContentControl.Resources>
                                <!-- Текст книги -->
                                <DataTemplate DataType="{x:Type vm:BookContentViewModel}">
                                    <FlowDocumentScrollViewer>
                                        <FlowDocument FontFamily="{Binding SelectedFont}" FontSize="{Binding FontSize}" 
                                                      Background="{Binding BackgroundColor}" Foreground="{Binding FontColor}">
                                            <Paragraph TextAlignment="Justify">
                                                <Run Text="{Binding BookContent}"/>
                                            </Paragraph>
                                        </FlowDocument>
                                    </FlowDocumentScrollViewer>
                                </DataTemplate>
                                <!-- Настройки -->
                                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Row="0" Grid.Column="0" Content="Шрифт:"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AvailableFonts}" 
                                                  SelectedItem="{Binding SelectedFont, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Label Grid.Row="1" Grid.Column="0" Content="Размер шрифта:"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" 
                                                 Width="50" HorizontalAlignment="Left"/>
                                        <Label Grid.Row="2" Grid.Column="0" Content="Цвет фона:"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AvailableColors}" 
                                                  SelectedItem="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Label Grid.Row="3" Grid.Column="0" Content="Цвет текста:"/>
                                        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding AvailableColors}" 
                                                  SelectedItem="{Binding FontColor, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>
                                </DataTemplate>
                                <!-- Избранные книги -->
                                <DataTemplate DataType="{x:Type vm:FavoritesViewModel}">
                                    <ListView ItemsSource="{Binding FavoriteBooks}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Title}" Width="200"/>
                                                <GridViewColumn Header="Автор" DisplayMemberBinding="{Binding Author}" Width="150"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </DataTemplate>
                                <!-- История чтения -->
                                <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
                                    <ListView ItemsSource="{Binding ReadingHistory}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Title}" Width="200"/>
                                                <GridViewColumn Header="Последняя страница" DisplayMemberBinding="{Binding LastReadPage}" Width="100"/>
                                                <GridViewColumn Header="Дата" DisplayMemberBinding="{Binding LastReadDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </DataTemplate>
                                <!-- Рекомендации -->
                                <DataTemplate DataType="{x:Type vm:RecommendationsViewModel}">
                                    <ListView ItemsSource="{Binding RecommendedBooks}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Title}" Width="200"/>
                                                <GridViewColumn Header="Автор" DisplayMemberBinding="{Binding Author}" Width="150"/>
                                                <GridViewColumn Header="Жанр" DisplayMemberBinding="{Binding Genre}" Width="100"/>
                                                <GridViewColumn Header="Рейтинг" DisplayMemberBinding="{Binding AverageRating, StringFormat={}{0:F1}}" Width="80"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </DataTemplate>
                            </ContentControl.Resources>
                        </ContentControl>
                    </Grid>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>